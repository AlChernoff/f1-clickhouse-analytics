{
  "id": null,
  "uid": "f1-loader-monitoring",
  "title": "F1 Loader Monitoring",
  "tags": ["f1", "clickhouse", "loader", "monitoring"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": {
    "from": "now-30d",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Rows loaded",
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT sum(rows_loaded) AS rows_loaded FROM monitoring.load_batches WHERE status = 'success'",
          "format": 1
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Successful batches",
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT count() AS successful_batches FROM monitoring.load_batches WHERE status = 'success'",
          "format": 1
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Failed batches",
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT count() AS failed_batches FROM monitoring.load_batches WHERE status = 'failed'",
          "format": 1
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Avg batch duration, ms",
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT avg(duration_ms) AS avg_duration_ms FROM monitoring.load_batches WHERE status = 'success'",
          "format": 1
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Rows loaded per minute",
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT minute AS time, target_table, sum(rows_loaded) AS rows_loaded FROM monitoring.loader_stats_1m WHERE minute >= $__fromTime AND minute <= $__toTime GROUP BY time, target_table ORDER BY time",
          "format": 0
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Batches per minute",
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT minute AS time, target_table, sum(batches_count) AS batches_count FROM monitoring.loader_stats_1m WHERE minute >= $__fromTime AND minute <= $__toTime GROUP BY time, target_table ORDER BY time",
          "format": 0
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      }
    },
    {
      "id": 7,
      "type": "table",
      "title": "Latest load batches",
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 12
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT started_at, source_name, target_table, rows_loaded, duration_ms, status, error_message FROM monitoring.load_batches ORDER BY started_at DESC LIMIT 50",
          "format": 1
        }
      ],
      "options": {
        "showHeader": true,
        "cellHeight": "sm"
      }
    },
    {
      "id": 8,
      "type": "table",
      "title": "Pipeline status",
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 20
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT status_time, component, status, message, details FROM monitoring.pipeline_status ORDER BY status_time DESC LIMIT 50",
          "format": 1
        }
      ],
      "options": {
        "showHeader": true,
        "cellHeight": "sm"
      }
    },
    {
      "id": 9,
      "type": "stat",
      "title": "Pipeline failures",
      "description": "Failed pipeline runs in the selected time range.",
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse"
      },
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 0,
        "y": 28
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT countIf(status = 'failed') AS failed_runs FROM monitoring.pipeline_status WHERE status_time >= $__fromTime AND status_time <= $__toTime",
          "format": 1
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "green", "value": null}, {"color": "red", "value": 1}]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {"values": false, "calcs": ["lastNotNull"], "fields": ""},
        "colorMode": "value",
        "graphMode": "area"
      }
    },
    {
      "id": 10,
      "type": "stat",
      "title": "Last successful batch",
      "description": "Completion timestamp of the most recent successful batch.",
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse"
      },
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 8,
        "y": 28
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT max(finished_at) AS last_success_at FROM monitoring.load_batches WHERE status = 'success'",
          "format": 1
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "dateTimeAsSystem"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {"values": false, "calcs": ["lastNotNull"], "fields": ""},
        "colorMode": "value",
        "graphMode": "none"
      }
    },
    {
      "id": 11,
      "type": "stat",
      "title": "Latest error",
      "description": "Time elapsed since the most recent recorded loader error.",
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse"
      },
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 16,
        "y": 28
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT max(occurred_at) AS latest_error_at FROM monitoring.load_errors",
          "format": 1
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "dateTimeAsSystem"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {"values": false, "calcs": ["lastNotNull"], "fields": ""},
        "colorMode": "value",
        "graphMode": "none"
      }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Batch error rate, %",
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 32
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT minute AS time, 100.0 * sum(failed_count) / nullIf(sum(batches_count), 0) AS error_rate_pct FROM monitoring.loader_stats_1m WHERE minute >= $__fromTime AND minute <= $__toTime GROUP BY time ORDER BY time",
          "format": 0
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "green", "value": null}, {"color": "orange", "value": 1}, {"color": "red", "value": 5}]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "single", "sort": "none"}
      }
    },
    {
      "id": 13,
      "type": "table",
      "title": "Latest loader errors",
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 32
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT occurred_at, source_name, target_table, error_message FROM monitoring.load_errors ORDER BY occurred_at DESC LIMIT 25",
          "format": 1
        }
      ],
      "options": {
        "showHeader": true,
        "cellHeight": "sm"
      }
    }
  ]
}
