# Local Docker Compose configuration. Copy this file to .env before the first run.
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_PORT=9000
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_USER=f1_app
CLICKHOUSE_PASSWORD=f1_app_password

GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

SUPERSET_PORT=8088
SUPERSET_ADMIN_USER=admin
SUPERSET_ADMIN_PASSWORD=admin
SUPERSET_ADMIN_EMAIL=admin@example.com
# Replace with a long random value outside local development.
SUPERSET_SECRET_KEY=change-this-local-superset-secret-key
