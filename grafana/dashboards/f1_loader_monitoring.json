{
  "id": null,
  "uid": "f1-loader-monitoring",
  "title": "F1 Loader Monitoring",
  "tags": ["f1", "clickhouse", "loader", "monitoring"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 5,
  "refresh": "10s",
  "time": {
    "from": "now-30d",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Rows published",
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT sum(rows_loaded) AS rows_published FROM monitoring.load_batches WHERE status = 'success'",
          "format": 1
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Successful batches",
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT count() AS successful_batches FROM monitoring.load_batches WHERE status = 'success'",
          "format": 1
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Failed batches",
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT count() AS failed_batches FROM monitoring.load_batches WHERE status = 'failed'",
          "format": 1
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Avg batch duration, ms",
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT avg(duration_ms) AS avg_duration_ms FROM monitoring.load_batches WHERE status = 'success'",
          "format": 1
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Rows published per minute",
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 4
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT minute AS time, target_table, sum(rows_loaded) AS rows_published FROM monitoring.loader_stats_1m WHERE minute >= $__fromTime AND minute <= $__toTime GROUP BY time, target_table ORDER BY time",
          "format": 0
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Batches per minute",
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 4
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT minute AS time, target_table, sum(batches_count) AS batches_count FROM monitoring.loader_stats_1m WHERE minute >= $__fromTime AND minute <= $__toTime GROUP BY time, target_table ORDER BY time",
          "format": 0
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      }
    },
    {
      "id": 7,
      "type": "table",
      "title": "Latest producer batches",
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 12
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT started_at, source_name, target_table, rows_loaded, duration_ms, status, error_message FROM monitoring.load_batches ORDER BY started_at DESC LIMIT 50",
          "format": 1
        }
      ],
      "options": {
        "showHeader": true,
        "cellHeight": "sm"
      }
    },
    {
      "id": 8,
      "type": "table",
      "title": "Pipeline status",
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 20
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT status_time, component, status, message, details FROM monitoring.pipeline_status ORDER BY status_time DESC LIMIT 50",
          "format": 1
        }
      ],
      "options": {
        "showHeader": true,
        "cellHeight": "sm"
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Average producer duration per minute",
      "description": "Average time to publish one batch to Kafka.",
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 28
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT minute AS time, target_table, round(sum(total_duration_ms) / nullIf(sum(batches_count), 0), 2) AS avg_duration_ms FROM monitoring.loader_stats_1m WHERE minute >= $__fromTime AND minute <= $__toTime GROUP BY time, target_table ORDER BY time",
          "format": 0
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        },
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "none"}
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Successful and failed batches per minute",
      "description": "Producer delivery outcomes grouped by minute.",
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 28
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT minute AS time, sum(success_count) AS successful_batches, sum(failed_count) AS failed_batches FROM monitoring.loader_stats_1m WHERE minute >= $__fromTime AND minute <= $__toTime GROUP BY time ORDER BY time",
          "format": 0
        }
      ],
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "none"}
      }
    }
  ]
}
